# Bitcoin Core JSON-RPC
BTC_RPC_URL=http://host.docker.internal:8332
BTC_RPC_USER=
BTC_RPC_PASSWORD=
# Leave USER/PASSWORD blank and set this if you use the cookie file instead:
# BTC_COOKIE_FILE=/root/.bitcoin/.cookie

# Counterparty Core v2 API
CP_API_URL=http://host.docker.internal:4000

# Indexer behaviour
COUNTER_START_HEIGHT=0        # 0 = exhaustive scan; use 955251 to start from genesis
COUNTER_POLL_INTERVAL=15      # seconds between tip checks
COUNTER_CONFIRMATIONS=0       # required confirmations before indexing a block

# Storage (inside the container; change only if you override the volume mount)
COUNTER_DATA_DIR=/data
